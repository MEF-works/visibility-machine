# Copy to .env on Prod-Ops at /opt/apps/visibility-machine/.env
GEMINI_API_KEY=your_key_here
NODE_ENV=production
PORT=3000

# Traefik BasicAuth gate (required in production — blocks public access)
# Generate: htpasswd -nb mefworks YOUR_PASSWORD
# In .env use single $ — docker-compose.yml escapes to $$ in labels
# Example: BASIC_AUTH_HTPASSWD=mefworks:$apr1$xxxx$hash
BASIC_AUTH_HTPASSWD=
